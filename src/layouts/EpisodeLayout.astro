---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import AudioPlayer from '../components/global/AudioPlayer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
}

const { title, description, ogImage, pubDate } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType="article">
  <slot name="head" slot="head" />

  <Header currentPath={currentPath} />

  <main id="main-content" transition:animate="fade">
    <slot />
  </main>

  <Footer />

  <AudioPlayer />
</BaseLayout>
