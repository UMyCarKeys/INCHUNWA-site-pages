---
---

<div id="audio-player" class="audio-player" data-hidden="true" transition:persist>
  <audio id="audio-element" preload="metadata"></audio>

  <div class="audio-player__inner">
    {/* Minimize toggle */}
    <button class="audio-player__minimize" aria-label="Minimize player" id="player-minimize">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 15 12 9 18 15" id="minimize-icon" />
      </svg>
    </button>

    {/* Now Playing Info */}
    <div class="audio-player__info">
      <a href="#" class="audio-player__title" id="player-title">No episode loaded</a>
    </div>

    {/* Controls */}
    <div class="audio-player__controls">
      <button class="player-btn" id="player-skip-back" aria-label="Skip back 15 seconds">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 4v6h6" /><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
        </svg>
        <span class="player-btn__label">15</span>
      </button>

      <button class="player-btn player-btn--play" id="player-play" aria-label="Play">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" id="play-icon">
          <polygon points="5,3 19,12 5,21" />
        </svg>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" id="pause-icon" style="display:none;">
          <rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" />
        </svg>
      </button>

      <button class="player-btn" id="player-skip-forward" aria-label="Skip forward 15 seconds">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 4v6h-6" /><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10" />
        </svg>
        <span class="player-btn__label">15</span>
      </button>
    </div>

    {/* Progress */}
    <div class="audio-player__progress">
      <span class="audio-player__time" id="player-current">0:00</span>
      <input
        type="range"
        class="audio-player__scrubber"
        id="player-scrubber"
        min="0"
        max="100"
        value="0"
        step="0.1"
        aria-label="Seek"
      />
      <span class="audio-player__time" id="player-duration">0:00</span>
    </div>

    {/* Volume */}
    <div class="audio-player__volume">
      <button class="player-btn" id="player-mute" aria-label="Mute">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="volume-icon">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" />
        </svg>
      </button>
      <input
        type="range"
        class="audio-player__volume-slider"
        id="player-volume"
        min="0"
        max="1"
        value="0.8"
        step="0.05"
        aria-label="Volume"
      />
    </div>
  </div>
</div>

<script>
  // Use an IIFE to avoid polluting global scope and prevent duplicate listeners
  (function () {
    // Guard: only init once globally
    if ((window as any).__inchunwaPlayerInit) return;
    (window as any).__inchunwaPlayerInit = true;

    const player = document.getElementById('audio-player') as HTMLElement;
    const audio = document.getElementById('audio-element') as HTMLAudioElement;
    const titleEl = document.getElementById('player-title') as HTMLAnchorElement;
    const playBtn = document.getElementById('player-play') as HTMLButtonElement;
    const playIcon = document.getElementById('play-icon') as SVGElement;
    const pauseIcon = document.getElementById('pause-icon') as SVGElement;
    const skipBack = document.getElementById('player-skip-back') as HTMLButtonElement;
    const skipForward = document.getElementById('player-skip-forward') as HTMLButtonElement;
    const scrubber = document.getElementById('player-scrubber') as HTMLInputElement;
    const currentTimeEl = document.getElementById('player-current') as HTMLElement;
    const durationEl = document.getElementById('player-duration') as HTMLElement;
    const muteBtn = document.getElementById('player-mute') as HTMLButtonElement;
    const volumeSlider = document.getElementById('player-volume') as HTMLInputElement;
    const minimizeBtn = document.getElementById('player-minimize') as HTMLButtonElement;
    const minimizeIcon = document.getElementById('minimize-icon') as SVGElement;

    if (!player || !audio) return;

    let isMinimized = false;

    function formatTime(seconds: number): string {
      if (isNaN(seconds)) return '0:00';
      const m = Math.floor(seconds / 60);
      const s = Math.floor(seconds % 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    }

    function updatePlayState() {
      if (audio.paused) {
        playIcon.style.display = '';
        pauseIcon.style.display = 'none';
        playBtn.setAttribute('aria-label', 'Play');
      } else {
        playIcon.style.display = 'none';
        pauseIcon.style.display = '';
        playBtn.setAttribute('aria-label', 'Pause');
      }
    }

    // Play/Pause
    playBtn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play().catch(() => {});
      } else {
        audio.pause();
      }
    });

    audio.addEventListener('play', updatePlayState);
    audio.addEventListener('pause', updatePlayState);

    // Skip
    skipBack.addEventListener('click', () => { audio.currentTime = Math.max(0, audio.currentTime - 15); });
    skipForward.addEventListener('click', () => { audio.currentTime = Math.min(audio.duration, audio.currentTime + 15); });

    // Progress
    audio.addEventListener('timeupdate', () => {
      if (!isNaN(audio.duration)) {
        const pct = (audio.currentTime / audio.duration) * 100;
        scrubber.value = pct.toString();
        currentTimeEl.textContent = formatTime(audio.currentTime);
      }
    });

    audio.addEventListener('loadedmetadata', () => {
      durationEl.textContent = formatTime(audio.duration);
    });

    scrubber.addEventListener('input', () => {
      if (!isNaN(audio.duration)) {
        audio.currentTime = (parseFloat(scrubber.value) / 100) * audio.duration;
      }
    });

    // Volume
    volumeSlider.addEventListener('input', () => {
      audio.volume = parseFloat(volumeSlider.value);
      audio.muted = false;
    });

    muteBtn.addEventListener('click', () => {
      audio.muted = !audio.muted;
    });

    // Minimize
    minimizeBtn.addEventListener('click', () => {
      isMinimized = !isMinimized;
      player.classList.toggle('is-minimized', isMinimized);
      minimizeIcon.setAttribute('points', isMinimized ? '6 9 12 15 18 9' : '6 15 12 9 18 15');
      minimizeBtn.setAttribute('aria-label', isMinimized ? 'Expand player' : 'Minimize player');
    });

    // Listen for play-episode events (single global listener)
    window.addEventListener('play-episode', ((e: CustomEvent) => {
      const { title, audioUrl, episodeUrl } = e.detail;
      titleEl.textContent = title;
      titleEl.href = episodeUrl || '#';
      audio.src = audioUrl;
      audio.play().catch((err: Error) => {
        console.warn('Autoplay blocked, user must click play:', err.message);
      });
      player.dataset.hidden = 'false';

      // Save state
      try {
        sessionStorage.setItem('inchunwa-player', JSON.stringify({ title, audioUrl, episodeUrl }));
      } catch {}
    }) as EventListener);

    // Restore state (don't autoplay on restore — just show player)
    try {
      const saved = sessionStorage.getItem('inchunwa-player');
      if (saved) {
        const state = JSON.parse(saved);
        titleEl.textContent = state.title;
        titleEl.href = state.episodeUrl || '#';
        audio.src = state.audioUrl;
        player.dataset.hidden = 'false';
      }
    } catch {}
  })();
</script>

<style>
  .audio-player {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: var(--z-audio-player);
    background: var(--bg-dark);
    color: var(--text-on-dark);
    transform: translateY(0);
    transition: transform var(--transition-base);
    box-shadow: 0 -4px 20px rgba(31, 3, 0, 0.2);
  }

  .audio-player[data-hidden="true"] {
    transform: translateY(100%);
  }

  .audio-player__inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--gutter);
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .audio-player.is-minimized .audio-player__controls,
  .audio-player.is-minimized .audio-player__progress,
  .audio-player.is-minimized .audio-player__volume {
    display: none;
  }

  .audio-player__minimize {
    flex-shrink: 0;
    color: rgba(253, 250, 250, 0.5);
    padding: 4px;
  }

  .audio-player__minimize:hover {
    color: var(--color-white);
  }

  .audio-player__info {
    min-width: 0;
    flex: 0 1 200px;
  }

  .audio-player__title {
    display: block;
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
  }

  .audio-player__title:hover {
    color: var(--color-pink);
  }

  .audio-player__controls {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-shrink: 0;
  }

  .player-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: rgba(253, 250, 250, 0.8);
    transition: all var(--transition-fast);
  }

  .player-btn:hover {
    color: var(--color-white);
    background: rgba(253, 250, 250, 0.1);
  }

  .player-btn--play {
    width: 44px;
    height: 44px;
    background: var(--color-dark-red);
    color: var(--color-white);
    padding-inline-start: 2px;
  }

  .player-btn--play:hover {
    background: var(--color-light-red);
  }

  .player-btn__label {
    position: absolute;
    font-size: 8px;
    font-weight: 700;
    bottom: 4px;
  }

  .audio-player__progress {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex: 1;
    min-width: 0;
  }

  .audio-player__time {
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    color: rgba(253, 250, 250, 0.6);
    flex-shrink: 0;
    width: 3em;
    text-align: center;
  }

  .audio-player__scrubber,
  .audio-player__volume-slider {
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    background: rgba(253, 250, 250, 0.2);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .audio-player__scrubber {
    flex: 1;
  }

  .audio-player__scrubber::-webkit-slider-thumb,
  .audio-player__volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-pink);
    cursor: pointer;
    border: none;
  }

  .audio-player__volume {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-shrink: 0;
  }

  .audio-player__volume-slider {
    width: 80px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .audio-player__inner {
      flex-wrap: wrap;
      gap: var(--space-xs);
    }

    .audio-player__volume {
      display: none;
    }

    .audio-player__info {
      flex: 1;
    }

    .audio-player__progress {
      order: 10;
      flex-basis: 100%;
    }
  }

  @media (max-width: 480px) {
    .audio-player.is-minimized .audio-player__inner {
      padding-block: 6px;
    }
  }
</style>
