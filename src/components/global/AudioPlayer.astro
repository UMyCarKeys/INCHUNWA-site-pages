---
---

<div id="audio-player" class="audio-player" data-hidden="true" transition:persist>
  <div class="audio-player__bar">
    <button class="audio-player__minimize" aria-label="Minimize player" id="player-minimize">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 15 12 9 18 15" id="minimize-icon" />
      </svg>
    </button>

    <a href="#" class="audio-player__title" id="player-title">No episode loaded</a>

    <button class="audio-player__close" aria-label="Close player" id="player-close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <div class="audio-player__embed" id="player-embed">
    <!-- Buzzsprout iframe injected here on play -->
  </div>
</div>

<script>
  (function () {
    if ((window as any).__inchunwaPlayerInit) return;
    (window as any).__inchunwaPlayerInit = true;

    const player   = document.getElementById('audio-player') as HTMLElement;
    const titleEl  = document.getElementById('player-title') as HTMLAnchorElement;
    const embedEl  = document.getElementById('player-embed') as HTMLElement;
    const minimize = document.getElementById('player-minimize') as HTMLButtonElement;
    const closeBtn = document.getElementById('player-close') as HTMLButtonElement;
    const minIcon  = document.getElementById('minimize-icon') as SVGPolylineElement;

    if (!player) return;

    let isMinimized = false;

    function loadEpisode(episodeId: string, title: string, episodeUrl: string) {
      titleEl.textContent = title;
      titleEl.href = episodeUrl || '#';

      // Clear previous embed and any Buzzsprout script tags we injected
      embedEl.innerHTML = `<div id="buzzsprout-player-${episodeId}"></div>`;
      document.querySelectorAll('script[data-bz-ep]').forEach(s => s.remove());

      // Use Buzzsprout's official JS embed — it creates its own iframe internally
      // with the correct auth/CDN context so audio.buzzsprout.com isn't blocked
      const script = document.createElement('script');
      script.src = `https://www.buzzsprout.com/1810796/${episodeId}.js?container_id=buzzsprout-player-${episodeId}&player=small`;
      script.setAttribute('data-bz-ep', episodeId);
      script.charset = 'utf-8';
      document.body.appendChild(script);

      player.dataset.hidden = 'false';
      if (isMinimized) {
        isMinimized = false;
        player.classList.remove('is-minimized');
        minIcon.setAttribute('points', '6 15 12 9 18 15');
        minimize.setAttribute('aria-label', 'Minimize player');
      }
    }

    minimize.addEventListener('click', () => {
      isMinimized = !isMinimized;
      player.classList.toggle('is-minimized', isMinimized);
      minIcon.setAttribute('points', isMinimized ? '6 9 12 15 18 9' : '6 15 12 9 18 15');
      minimize.setAttribute('aria-label', isMinimized ? 'Expand player' : 'Minimize player');
    });

    closeBtn.addEventListener('click', () => {
      player.dataset.hidden = 'true';
      embedEl.innerHTML = '';
      document.querySelectorAll('script[data-bz-ep]').forEach(s => s.remove());
      sessionStorage.removeItem('inchunwa-player');
    });

    window.addEventListener('play-episode', ((e: CustomEvent) => {
      const { title, audioUrl, episodeUrl } = e.detail;
      const episodeId = (audioUrl as string).match(/\/(\d+)\.mp3/)?.[1];
      if (!episodeId) return;
      loadEpisode(episodeId, title, episodeUrl);
      try {
        sessionStorage.setItem('inchunwa-player', JSON.stringify({ title, audioUrl, episodeUrl }));
      } catch {}
    }) as EventListener);

    // Restore last session
    try {
      const saved = sessionStorage.getItem('inchunwa-player');
      if (saved) {
        const state = JSON.parse(saved);
        const episodeId = state.audioUrl?.match(/\/(\d+)\.mp3/)?.[1];
        if (episodeId) {
          titleEl.textContent = state.title;
          titleEl.href = state.episodeUrl || '#';
          player.dataset.hidden = 'false';
          // Don't auto-load iframe on restore — user must click play again
        }
      }
    } catch {}
  })();
</script>

<style>
  .audio-player {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: var(--z-audio-player);
    background: var(--bg-dark);
    color: var(--text-on-dark);
    transform: translateY(0);
    transition: transform var(--transition-base);
    box-shadow: 0 -4px 20px rgba(31, 3, 0, 0.3);
  }

  .audio-player[data-hidden="true"] {
    transform: translateY(100%);
  }

  /* Bar: title row */
  .audio-player__bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--gutter);
    max-width: var(--max-width);
    margin-inline: auto;
    border-block-end: 1px solid rgba(253, 250, 250, 0.08);
  }

  .audio-player__minimize,
  .audio-player__close {
    flex-shrink: 0;
    color: rgba(253, 250, 250, 0.5);
    padding: 4px;
    transition: color var(--transition-fast);
  }

  .audio-player__minimize:hover,
  .audio-player__close:hover {
    color: var(--color-white);
  }

  .audio-player__title {
    flex: 1;
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
  }

  .audio-player__title:hover {
    color: var(--color-pink);
  }

  /* Embed area */
  .audio-player__embed {
    max-width: var(--max-width);
    margin-inline: auto;
    overflow: hidden;
    transition: max-height var(--transition-base);
    max-height: 200px;
  }

  .audio-player__embed iframe {
    display: block;
    width: 100%;
    height: 200px;
    border: none;
  }

  /* Minimized: hide the embed, only show bar */
  .audio-player.is-minimized .audio-player__embed {
    max-height: 0;
  }
</style>
