---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['motif-divider', className]} role="separator">
  <svg viewBox="0 0 400 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="motif-svg">
    {/* Geometric pattern inspired by Southeastern Indigenous design — diamond/cross motifs */}
    {/* This is a placeholder pattern — final designs should be reviewed by the Inchunwa team */}
    <line x1="0" y1="12" x2="140" y2="12" stroke="currentColor" stroke-width="1" opacity="0.3" />
    <polygon points="150,2 160,12 150,22 140,12" fill="none" stroke="currentColor" stroke-width="1.5" />
    <polygon points="170,5 177,12 170,19 163,12" fill="currentColor" opacity="0.6" />
    <circle cx="190" cy="12" r="3" fill="currentColor" />
    <circle cx="200" cy="12" r="2" fill="currentColor" opacity="0.5" />
    <circle cx="210" cy="12" r="3" fill="currentColor" />
    <polygon points="230,5 237,12 230,19 223,12" fill="currentColor" opacity="0.6" />
    <polygon points="250,2 260,12 250,22 240,12" fill="none" stroke="currentColor" stroke-width="1.5" />
    <line x1="260" y1="12" x2="400" y2="12" stroke="currentColor" stroke-width="1" opacity="0.3" />
  </svg>
</div>

<style>
  .motif-divider {
    display: flex;
    justify-content: center;
    padding-block: var(--space-lg);
    color: var(--color-pink);
  }

  .motif-svg {
    width: min(100%, 400px);
    height: 24px;
  }
</style>
