---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, subtitle, align = 'left', class: className = '' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, className]}>
  <h2 class="section-heading__title">{title}</h2>
  {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-block-end: var(--space-xl);
  }

  .section-heading--center {
    text-align: center;
  }

  .section-heading--center .section-heading__subtitle {
    margin-inline: auto;
  }

  .section-heading__title {
    margin-block-end: var(--space-sm);
  }

  .section-heading__subtitle {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 55ch;
  }
</style>
