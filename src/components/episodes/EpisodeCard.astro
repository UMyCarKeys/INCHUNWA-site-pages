---
import { url } from '../../utils/paths';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  duration: string;
  series?: string;
  episodeNumber?: number;
  audioUrl: string;
}

const { id, title, description, pubDate, duration, series, episodeNumber, audioUrl } = Astro.props;
const episodeUrl = url(`/episodes/${id}`);
---

<article class="episode-card hover-lift" data-series={series || 'all'}>
  <a href={episodeUrl} class="episode-card__link">
    <div class="episode-card__meta">
      {series && <span class="episode-card__series">{series}</span>}
      {episodeNumber && <span class="episode-card__number">Ep. {episodeNumber}</span>}
    </div>
    <h3 class="episode-card__title">{title}</h3>
    <p class="episode-card__desc">{description}</p>
    <div class="episode-card__footer">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </time>
      <span class="episode-card__duration">{duration}</span>
    </div>
  </a>
  <button
    class="episode-card__play"
    aria-label={`Play ${title}`}
    data-audio-url={audioUrl}
    data-episode-title={title}
    data-episode-url={episodeUrl}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <polygon points="5,3 19,12 5,21" />
    </svg>
  </button>
</article>

<style>
  .episode-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .episode-card__link {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    padding-inline-end: 4rem;
    text-decoration: none;
    color: inherit;
    min-height: 100%;
  }

  .episode-card__link:hover {
    color: inherit;
  }

  .episode-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-block-end: var(--space-sm);
  }

  .episode-card__series {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-dark-red);
    background: rgba(154, 2, 1, 0.08);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-full);
  }

  .episode-card__number {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .episode-card__title {
    font-size: var(--text-lg);
    font-family: var(--font-display);
    margin-block-end: var(--space-sm);
    line-height: 1.3;
  }

  .episode-card__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-block-end: var(--space-md);
  }

  .episode-card__footer {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--text-muted);
    padding-block-start: var(--space-sm);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-card__duration {
    font-variant-numeric: tabular-nums;
  }

  .episode-card__play {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-md);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cta-bg);
    color: var(--cta-text);
    border-radius: 50%;
    transition: all var(--transition-fast);
    padding-inline-start: 2px;
  }

  .episode-card__play:hover {
    background: var(--cta-hover);
    transform: scale(1.1);
  }
</style>

<script>
  function initPlayButtons() {
    document.querySelectorAll('.episode-card__play').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const button = e.currentTarget as HTMLElement;
        window.dispatchEvent(new CustomEvent('play-episode', {
          detail: {
            title: button.dataset.episodeTitle,
            audioUrl: button.dataset.audioUrl,
            episodeUrl: button.dataset.episodeUrl,
          }
        }));
      });
    });
  }

  initPlayButtons();
  document.addEventListener('astro:after-swap', initPlayButtons);
</script>
