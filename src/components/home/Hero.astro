---
import Button from '../ui/Button.astro';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__pattern"></div>
  </div>
  <div class="container hero__content">
    <p class="hero__eyebrow animate-on-scroll">Southeastern Indigenous Tattoo Revitalization</p>
    <h1 class="hero__title animate-on-scroll">Reclaiming Ancestral Marks, Together</h1>
    <p class="hero__subtitle animate-on-scroll">
      A community-rooted podcast and project promoting body sovereignty through Indigenous Mississippian identity and cultural tattooing practices.
    </p>
    <div class="hero__actions animate-on-scroll">
      <Button href="/episodes" variant="primary" size="lg">Listen Now</Button>
      <Button href="/about" variant="outline" size="lg">Learn More</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(85vh, 700px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      var(--color-black) 0%,
      #2d0a07 40%,
      var(--color-dark-red) 100%
    );
  }

  .hero__pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      radial-gradient(circle at 20% 80%, var(--color-pink) 1px, transparent 1px),
      radial-gradient(circle at 80% 20%, var(--color-pink) 1px, transparent 1px),
      radial-gradient(circle at 50% 50%, var(--color-pink) 0.5px, transparent 0.5px);
    background-size: 60px 60px, 80px 80px, 40px 40px;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-2xl);
    max-width: 750px;
  }

  .hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-pink);
    margin-block-end: var(--space-md);
  }

  .hero__title {
    color: var(--color-white);
    font-size: var(--text-4xl);
    margin-block-end: var(--space-md);
    line-height: 1.1;
  }

  .hero__subtitle {
    color: rgba(253, 250, 250, 0.85);
    font-size: var(--text-lg);
    max-width: 55ch;
    margin-block-end: var(--space-xl);
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* Override outline button for dark background */
  .hero__actions :global(.btn--outline) {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .hero__actions :global(.btn--outline:hover) {
    background-color: var(--color-white);
    color: var(--color-black);
  }
</style>
