---
import { getCollection } from 'astro:content';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import { url } from '../../utils/paths';

const episodes = await getCollection('episodes', ({ data }) => !data.draft);
const latestEpisodes = episodes
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<section class="section latest-episodes">
  <div class="container">
    <SectionHeading
      title="Latest Episodes"
      subtitle="Listen to the most recent conversations from the Inchunwa Project."
      align="center"
    />

    <div class="episodes-grid stagger-children">
      {latestEpisodes.map((episode) => (
        <a href={url(`/episodes/${episode.id}`)} class="episode-card animate-on-scroll hover-lift">
          <div class="episode-card__meta">
            {episode.data.series && (
              <span class="episode-card__series">{episode.data.series}</span>
            )}
            <span class="episode-card__number">
              {episode.data.episodeNumber ? `Ep. ${episode.data.episodeNumber}` : ''}
            </span>
          </div>
          <h3 class="episode-card__title">{episode.data.title}</h3>
          <p class="episode-card__desc">{episode.data.description}</p>
          <div class="episode-card__footer">
            <time datetime={episode.data.pubDate.toISOString()}>
              {episode.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <span class="episode-card__duration">{episode.data.duration}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="latest-episodes__cta text-center">
      <Button href={url('/episodes')} variant="outline">View All Episodes</Button>
    </div>
  </div>
</section>

<style>
  .episodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }

  .episode-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .episode-card:hover {
    color: inherit;
  }

  .episode-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-block-end: var(--space-sm);
  }

  .episode-card__series {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-dark-red);
    background: rgba(154, 2, 1, 0.08);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-full);
  }

  .episode-card__number {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 500;
  }

  .episode-card__title {
    font-size: var(--text-xl);
    margin-block-end: var(--space-sm);
    font-family: var(--font-display);
    line-height: 1.3;
  }

  .episode-card__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    flex: 1;
    margin-block-end: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .episode-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-xs);
    color: var(--text-muted);
    padding-block-start: var(--space-sm);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-card__duration {
    font-variant-numeric: tabular-nums;
  }

  .latest-episodes__cta {
    margin-block-start: var(--space-lg);
  }
</style>
