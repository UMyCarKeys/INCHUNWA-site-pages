---
import { getCollection, render } from 'astro:content';
import EpisodeLayout from '../../layouts/EpisodeLayout.astro';
import Button from '../../components/ui/Button.astro';
import Tag from '../../components/ui/Tag.astro';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes', ({ data }) => !data.draft);
  return episodes.map((episode) => ({
    params: { id: episode.id },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const { Content } = await render(episode);
const { title, description, pubDate, series, episodeNumber, duration, audioUrl, hasTranscript, transcript, tags } = episode.data;

// Get prev/next episodes
const allEpisodes = await getCollection('episodes', ({ data }) => !data.draft);
const sorted = allEpisodes.sort((a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime());
const currentIndex = sorted.findIndex(e => e.id === episode.id);
const prevEpisode = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextEpisode = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<EpisodeLayout title={title} description={description}>

  <article class="episode-detail">
    {/* Episode Header */}
    <header class="episode-header">
      <div class="container container--narrow">
        <a href={url('/episodes')} class="episode-back">&larr; All Episodes</a>

        <div class="episode-meta">
          {series && <span class="episode-series">{series}</span>}
          {episodeNumber && <span class="episode-number">Episode {episodeNumber}</span>}
        </div>

        <h1 class="episode-title">{title}</h1>

        <div class="episode-info">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="episode-info__sep" aria-hidden="true">&middot;</span>
          <span>{duration}</span>
        </div>
      </div>
    </header>

    {/* Audio Player */}
    <section class="episode-player">
      <div class="container container--narrow">
        <div class="inline-player">
          <button
            class="inline-player__play"
            aria-label={`Play ${title}`}
            data-audio-url={audioUrl}
            data-episode-title={title}
            data-episode-url={url(`/episodes/${episode.id}`)}
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="5,3 19,12 5,21" />
            </svg>
          </button>
          <audio controls preload="metadata" class="inline-player__audio">
            <source src={audioUrl} type="audio/mpeg" />
            Your browser does not support the audio element.
          </audio>
        </div>
      </div>
    </section>

    {/* Show Notes */}
    <section class="episode-body">
      <div class="container container--narrow">
        <div class="prose">
          <Content />
        </div>

        {/* Tags */}
        {tags.length > 0 && (
          <div class="episode-tags">
            {tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        )}

        {/* Transcript */}
        {hasTranscript && transcript && (
          <details class="episode-transcript">
            <summary class="episode-transcript__toggle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9" />
              </svg>
              View Transcript
            </summary>
            <div class="episode-transcript__content prose">
              <p>{transcript}</p>
            </div>
          </details>
        )}
      </div>
    </section>

    {/* Previous / Next */}
    <nav class="episode-nav" aria-label="Episode navigation">
      <div class="container container--narrow">
        <div class="episode-nav__grid">
          {prevEpisode ? (
            <a href={url(`/episodes/${prevEpisode.id}`)} class="episode-nav__link episode-nav__prev">
              <span class="episode-nav__label">&larr; Previous</span>
              <span class="episode-nav__title">{prevEpisode.data.title}</span>
            </a>
          ) : <div />}

          {nextEpisode ? (
            <a href={url(`/episodes/${nextEpisode.id}`)} class="episode-nav__link episode-nav__next">
              <span class="episode-nav__label">Next &rarr;</span>
              <span class="episode-nav__title">{nextEpisode.data.title}</span>
            </a>
          ) : <div />}
        </div>
      </div>
    </nav>

    {/* Support CTA */}
    <section class="section section--accent text-center">
      <div class="container container--narrow">
        <h2>Support the Inchunwa Project</h2>
        <p style="margin-block: var(--space-md); color: var(--text-secondary);">
          If this episode resonated with you, consider supporting our work.
        </p>
        <Button href={url('/support')} variant="primary">Support Us</Button>
      </div>
    </section>
  </article>
</EpisodeLayout>

<script>
  function initInlinePlayer() {
    document.querySelectorAll('.inline-player__play').forEach((btn) => {
      btn.addEventListener('click', () => {
        const button = btn as HTMLElement;
        window.dispatchEvent(new CustomEvent('play-episode', {
          detail: {
            title: button.dataset.episodeTitle,
            audioUrl: button.dataset.audioUrl,
            episodeUrl: button.dataset.episodeUrl,
          }
        }));
      });
    });
  }

  initInlinePlayer();
  document.addEventListener('astro:after-swap', initInlinePlayer);
</script>

<style>
  .episode-header {
    background: linear-gradient(135deg, var(--color-black) 0%, #2d0a07 100%);
    color: var(--text-on-dark);
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .episode-back {
    display: inline-block;
    color: var(--color-pink);
    font-size: var(--text-sm);
    font-weight: 500;
    margin-block-end: var(--space-lg);
    transition: color var(--transition-fast);
  }

  .episode-back:hover {
    color: var(--color-white);
  }

  .episode-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-block-end: var(--space-sm);
  }

  .episode-series {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-black);
    background: var(--color-pink);
    padding: 0.2em 0.7em;
    border-radius: var(--radius-full);
  }

  .episode-number {
    font-size: var(--text-sm);
    color: rgba(253, 250, 250, 0.6);
  }

  .episode-title {
    color: var(--color-white);
    font-size: var(--text-3xl);
    margin-block-end: var(--space-md);
  }

  .episode-info {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: rgba(253, 250, 250, 0.7);
  }

  .episode-player {
    padding-block: var(--space-lg);
    background: var(--bg-card);
    border-block-end: 1px solid var(--border-light);
  }

  .inline-player {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .inline-player__play {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cta-bg);
    color: var(--cta-text);
    border-radius: 50%;
    padding-inline-start: 3px;
    transition: all var(--transition-fast);
  }

  .inline-player__play:hover {
    background: var(--cta-hover);
    transform: scale(1.05);
  }

  .inline-player__audio {
    flex: 1;
    height: 40px;
  }

  .episode-body {
    padding-block: var(--space-xl);
  }

  .episode-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-transcript {
    margin-block-start: var(--space-xl);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .episode-transcript__toggle {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    font-weight: 600;
    cursor: pointer;
    background: rgba(234, 168, 163, 0.08);
    transition: background var(--transition-fast);
    list-style: none;
  }

  .episode-transcript__toggle::-webkit-details-marker {
    display: none;
  }

  .episode-transcript__toggle:hover {
    background: rgba(234, 168, 163, 0.15);
  }

  .episode-transcript[open] .episode-transcript__toggle svg {
    transform: rotate(180deg);
  }

  .episode-transcript__toggle svg {
    transition: transform var(--transition-fast);
  }

  .episode-transcript__content {
    padding: var(--space-lg);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-nav {
    padding-block: var(--space-lg);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-nav__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  @media (max-width: 480px) {
    .episode-nav__grid {
      grid-template-columns: 1fr;
    }
  }

  .episode-nav__link {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    padding: var(--space-md);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-fast);
  }

  .episode-nav__link:hover {
    border-color: var(--color-pink);
    background: rgba(234, 168, 163, 0.05);
    color: inherit;
  }

  .episode-nav__next {
    text-align: end;
  }

  .episode-nav__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-dark-red);
  }

  .episode-nav__title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
  }
</style>
