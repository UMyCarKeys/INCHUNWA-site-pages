---
import { getCollection, render } from 'astro:content';
import EpisodeLayout from '../../layouts/EpisodeLayout.astro';
import Button from '../../components/ui/Button.astro';
import Tag from '../../components/ui/Tag.astro';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes', ({ data }) => !data.draft);
  return episodes.map((episode) => ({
    params: { id: episode.id },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const { Content } = await render(episode);
const { title, description, pubDate, series, episodeNumber, duration, audioUrl, hasTranscript, transcript, tags } = episode.data;
const buzzsproutId = audioUrl.match(/\/(\d+)\.mp3/)?.[1];

// Get prev/next episodes
const allEpisodes = await getCollection('episodes', ({ data }) => !data.draft);
const sorted = allEpisodes.sort((a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime());
const currentIndex = sorted.findIndex(e => e.id === episode.id);
const prevEpisode = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextEpisode = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<EpisodeLayout title={title} description={description}>

  <article class="episode-detail">
    {/* Episode Header */}
    <header class="episode-header">
      <div class="container container--narrow">
        <a href={url('/episodes')} class="episode-back">&larr; All Episodes</a>

        <div class="episode-meta">
          {series && <span class="episode-series">{series}</span>}
          {episodeNumber && <span class="episode-number">Episode {episodeNumber}</span>}
        </div>

        <h1 class="episode-title">{title}</h1>

        <div class="episode-info">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="episode-info__sep" aria-hidden="true">&middot;</span>
          <span>{duration}</span>
        </div>
      </div>
    </header>

    {/* Audio Player */}
    <section class="episode-player">
      <div class="container container--narrow">
        {buzzsproutId ? (
          <div id={`buzzsprout-player-${buzzsproutId}`} class="episode-embed-player"></div>
          <script define:vars={{ buzzsproutId }}>
            (function () {
              const s = document.createElement('script');
              s.src = 'https://www.buzzsprout.com/1810796/' + buzzsproutId + '.js?container_id=buzzsprout-player-' + buzzsproutId + '&player=small';
              s.charset = 'utf-8';
              document.body.appendChild(s);
            })();
          </script>
        ) : (
          <p>Audio unavailable.</p>
        )}
      </div>
    </section>

    {/* Show Notes */}
    <section class="episode-body">
      <div class="container container--narrow">
        <div class="prose">
          <Content />
        </div>

        {/* Tags */}
        {tags.length > 0 && (
          <div class="episode-tags">
            {tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        )}

        {/* Transcript */}
        {hasTranscript && transcript && (
          <details class="episode-transcript">
            <summary class="episode-transcript__toggle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9" />
              </svg>
              View Transcript
            </summary>
            <div class="episode-transcript__content prose">
              <p>{transcript}</p>
            </div>
          </details>
        )}
      </div>
    </section>

    {/* Previous / Next */}
    <nav class="episode-nav" aria-label="Episode navigation">
      <div class="container container--narrow">
        <div class="episode-nav__grid">
          {prevEpisode ? (
            <a href={url(`/episodes/${prevEpisode.id}`)} class="episode-nav__link episode-nav__prev">
              <span class="episode-nav__label">&larr; Previous</span>
              <span class="episode-nav__title">{prevEpisode.data.title}</span>
            </a>
          ) : <div />}

          {nextEpisode ? (
            <a href={url(`/episodes/${nextEpisode.id}`)} class="episode-nav__link episode-nav__next">
              <span class="episode-nav__label">Next &rarr;</span>
              <span class="episode-nav__title">{nextEpisode.data.title}</span>
            </a>
          ) : <div />}
        </div>
      </div>
    </nav>

    {/* Support CTA */}
    <section class="section section--accent text-center">
      <div class="container container--narrow">
        <h2>Support the Inchunwa Project</h2>
        <p style="margin-block: var(--space-md); color: var(--text-secondary);">
          If this episode resonated with you, consider supporting our work.
        </p>
        <Button href={url('/support')} variant="primary">Support Us</Button>
      </div>
    </section>
  </article>
</EpisodeLayout>


<style>
  .episode-header {
    background: linear-gradient(135deg, var(--color-black) 0%, #2d0a07 100%);
    color: var(--text-on-dark);
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .episode-back {
    display: inline-block;
    color: var(--color-pink);
    font-size: var(--text-sm);
    font-weight: 500;
    margin-block-end: var(--space-lg);
    transition: color var(--transition-fast);
  }

  .episode-back:hover {
    color: var(--color-white);
  }

  .episode-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-block-end: var(--space-sm);
  }

  .episode-series {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-black);
    background: var(--color-pink);
    padding: 0.2em 0.7em;
    border-radius: var(--radius-full);
  }

  .episode-number {
    font-size: var(--text-sm);
    color: rgba(253, 250, 250, 0.6);
  }

  .episode-title {
    color: var(--color-white);
    font-size: var(--text-3xl);
    margin-block-end: var(--space-md);
  }

  .episode-info {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: rgba(253, 250, 250, 0.7);
  }

  .episode-player {
    padding-block: var(--space-lg);
    background: var(--bg-card);
    border-block-end: 1px solid var(--border-light);
  }

  .episode-embed-player {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .episode-embed-player iframe {
    display: block;
    width: 100%;
    border: none;
  }

  .episode-body {
    padding-block: var(--space-xl);
  }

  .episode-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-transcript {
    margin-block-start: var(--space-xl);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .episode-transcript__toggle {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    font-weight: 600;
    cursor: pointer;
    background: rgba(234, 168, 163, 0.08);
    transition: background var(--transition-fast);
    list-style: none;
  }

  .episode-transcript__toggle::-webkit-details-marker {
    display: none;
  }

  .episode-transcript__toggle:hover {
    background: rgba(234, 168, 163, 0.15);
  }

  .episode-transcript[open] .episode-transcript__toggle svg {
    transform: rotate(180deg);
  }

  .episode-transcript__toggle svg {
    transition: transform var(--transition-fast);
  }

  .episode-transcript__content {
    padding: var(--space-lg);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-nav {
    padding-block: var(--space-lg);
    border-block-start: 1px solid var(--border-light);
  }

  .episode-nav__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  @media (max-width: 480px) {
    .episode-nav__grid {
      grid-template-columns: 1fr;
    }
  }

  .episode-nav__link {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    padding: var(--space-md);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-fast);
  }

  .episode-nav__link:hover {
    border-color: var(--color-pink);
    background: rgba(234, 168, 163, 0.05);
    color: inherit;
  }

  .episode-nav__next {
    text-align: end;
  }

  .episode-nav__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-dark-red);
  }

  .episode-nav__title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
  }
</style>
